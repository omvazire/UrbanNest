<% layout("/layouts/boilerplate") %>


  <div class="row mt-4">
    <div class="col-8 offset-3">
      <h3><b><%= foundListing.title %></b></h3>
      <br>
    </div>



    <div class="card col-6 offset-3 show-card listing-card">
      <img src="<%= foundListing.image.url %>"  class="card-img-top show-image" alt="Listing_image">
      <div class="card-body">
        <p class="card-text"> <br>

          <%= foundListing.description %> <br>
          <%= foundListing.location %> <br>
          <%= foundListing.country %> <br>
          &#8377; <%= foundListing.price.toLocaleString("en-IN") %>

        </p>
      </div>
    </div>


  </div>

  <div class="col-1 offset-3 mt-5">
    <a href="/listings/<%= foundListing._id %>/edit" class="btn btn-dark">Edit</a>
  </div>

  <div class="col-1 mt-3 offset-3">
    <form action="/listings/<%= foundListing._id %>?_method=DELETE" method="post">
      <button class="btn btn-danger">Delete</button>
    </form>
  </div>

<hr>
  <div class="col-8 offset-3 mb-3">
    <h4>Leave a Review</h4>

    <form action="/listings/<%= foundListing._id %>/reviews" method="POST" novalidate class="needs-validation">

      <div class="mb-4 mt-4">
        <label class="form-label" for="rating">Rating</label>
        <input type="range" class="form-range" min="1" max="5" name="review[rating]" id="rating">
      </div>

      <div class="mb-4 mt-4">
        <label class="form-label" for="comment">Comments</label>
        <textarea name="review[comment]" id="comment" cols="30" rows="5" class="form-control" required></textarea>

       <div class="invalid-feedback">Please add some comments for the review</div>

      </div>

      <button class="btn btn-outline-dark">Submit</button>

    </form>


    <hr>

<h4 class="mb-4"><b>All Reviews</b></h4>
<div class="row">
  
   <% for(review of foundListing.reviews) {%>
   <div class="card col-5 ms-3 mb-3">
     <div class="card-body">
      <h5 class="card-title">Card title</h5>
      <p class="card-text"><%= review.comment %></p>
      <p class="card-text"><%= review.rating %><span class="star">&#9733;</span></p>
     </div>

     <form action="/listings/<%= foundListing._id %>/reviews/<%= review._id %>?_method=DELETE" class="mb-3" method="POST">
      <button class="btn btn-sm btn-danger review-delete">Delete</button>
     </form>

   </div>
  <% } %>
</div>


  </div>