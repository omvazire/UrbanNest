<% layout("/layouts/boilerplate") %>

   <div class="row">
    <div class="col-8 offset-2">
<br><br><br>
        <h2>Create a new listing</h2> <br>
        <form action="/listings" method="post">
            <div class="mb-4">
                <label for="title" class="form-label">Title</label>
                <input type="text" name="listing[title]" id="" placeholder="Enter a appealing Title" class="form-control">
            </div>
            

            <div class="mb-4">
                <label for="description" class="form-label">Description</label>
                <textarea name="listing[description]" id="" placeholder="enter description"
                    class="form-control"></textarea>
            </div>
            

            <div class="mb-4">
                <label for="image" class="form-label">Image</label>
                <input type="text" name="listing[image]" id="" placeholder="Enter image URL/Link" class="form-control">
            </div>
            
            <div class="row">
                <div class="mb-4 col-md-4">
                <label for="price" class="form-label">Price</label>
                <input type="text" name="listing[price]" id="" placeholder="1200" class="form-control">

            </div>
            

            <div class="mb-4 col-md-8">
                <label for="country " class="form-label">Country</label>
                <input type="text" name="listing[country]" id="" placeholder="India" class="form-control">

            </div>
            </div>

            
            

            <div class="mb-4">
                <label for="location" class="form-label">location</label>
                <input type="text" name="listing[location]" id="" placeholder="Mumbai" class="form-control">
            </div>
            
            <button class="btn btn-dark list-btn">LIST</button>
        </form>
        <br><br><br>
    </div>
    </div>