<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>new listing</title>
</head>

<body>

    <h2>Create a new listing</h2>
    <form action="/listings" method="post">

        <input type="text" name="listing[title]" id="" placeholder="enter title"> <br><br>
        <textarea name="listing[description]" id="" placeholder="enter description"></textarea> <br><br>
        <input type="text" name="listing[image]" id="" placeholder="Enter image URL/Link"> <br><br>
        <input type="text" name="listing[price]" id="" placeholder="enter the price"> <br><br>
        <input type="text" name="listing[country]" id="" placeholder="enter country"> <br><br>
        <input type="text" name="listing[location]" id="" placeholder="enter location"> <br><br>

        <button>LIST</button>
    </form>
</body>

</html>